<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HeroTableParser.App"
             xmlns:local="using:HeroTableParser"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://HeroTableParser/Assets/Styles.axaml"/>
        <StyleInclude Source="avares://HeroTableParser/Assets/Icons.axaml"/>
    </Application.Styles>
</Application>