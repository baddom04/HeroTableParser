<!--
  MinusListView

  This user control allows the user to manage a list of heroes to exclude from selection or processing.

  Layout includes:
    - An AutoCompleteBox for selecting or typing a hero name to exclude.
    - An "Add" button to add the selected hero to the exclusion list.
    - A "Clear" button to clear the entire exclusion list.
    - A ListBox displaying the current list of excluded heroes.

  Data binding is set to the MinusListViewModel, which manages logic
  for adding, removing, and persisting excluded heroes.
-->

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:HeroTableParser.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="400"
             d:DesignHeight="450"
             x:Class="HeroTableParser.Views.MinusListView"
             x:DataType="vm:MinusListViewModel">

    <StackPanel Spacing="20" Margin="10">

        <!-- Header -->
        <TextBlock Text="Excluded Heroes"
                   FontWeight="Bold"
                   FontSize="16"
                   Margin="0,0,0,10"/>

        <!-- Input area for selecting a hero to exclude -->
        <StackPanel Orientation="Horizontal" Spacing="10">

            <AutoCompleteBox Width="200"
                             ItemsSource="{Binding HeroNames}"
                             Text="{Binding SelectedAntiHero, Mode=TwoWay}"
                             Watermark="Hero to exclude...">
                <AutoCompleteBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" />
                    </DataTemplate>
                </AutoCompleteBox.ItemTemplate>
            </AutoCompleteBox>

           <!-- Button to clear the entire exclusion list -->
            <Button ToolTip.Tip="Clear all"
                    Command="{Binding ClearList}">
                <PathIcon Data="{StaticResource delete_regular}"
                          Width="18"
                          Height="18"/>
            </Button>
        </StackPanel>

        <!-- List of currently excluded heroes -->
        <Border BorderBrush="#444" BorderThickness="1" CornerRadius="5" Padding="5">
            <ListBox ItemsSource="{Binding HeroesToExclude}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="14" Margin="4,2"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

    </StackPanel>
</UserControl>
