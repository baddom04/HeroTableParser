<!--
  MainWindow

  This is the main window for the HeroTableParser application.
  It provides the user interface for selecting a data sheet,
  entering enemy heroes, and displaying the best heroes to choose.

  Layout and Features:
    - Sheet Selection: ComboBox for selecting between sheets.
    - Path Update: Button to trigger Excel file path update.
    - Enemy Input: AutoCompleteBoxes for anti-heroes.
    - Best To Choose: List of heroes with their calculated scores.
    - MinusListView: Sidebar for managing excluded heroes.

  Data Binding:
    - Uses MainWindowViewModel as the DataContext.
    - AntiHeroes is a collection of AntiHero view models.
    - BestToChoose shows key-value pairs (hero name and score).
-->

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HeroTableParser.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:HeroTableParser.Views"
        mc:Ignorable="d"
        d:DesignWidth="800"
        d:DesignHeight="450"
        x:Class="HeroTableParser.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="HeroTableParser"
        Background="#1e1e1e"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True">

    <Grid Margin="30" ColumnDefinitions="*,300">
        <!-- Main vertical layout -->
        <StackPanel Spacing="20" Margin="30">
            
            <!-- Sheet selection and path update -->
            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0 10 0 0">
                <TextBlock Text="Selected sheet:" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding Sheets}" SelectedItem="{Binding SelectedSheet}"/>
                <Button Content="Path update" Click="NewPath_Click"/>
            </StackPanel>

            <!-- Enemy input controls -->
            <ItemsControl ItemsSource="{Binding AntiHeroes}" HorizontalAlignment="Stretch">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto, *, Auto" HorizontalAlignment="Center">
                            <TextBlock Grid.Column="0"
                                       Text="Enemy:"
                                       VerticalAlignment="Center"
                                       Margin="10"
                                       TextWrapping="Wrap"/>

                            <StackPanel Grid.Column="2"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal"
                                        Spacing="10">

                                <!-- AutoCompleteBox for selecting enemy hero -->
                                <AutoCompleteBox Margin="10"
                                                 ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).HeroNames}"
                                                 Text="{Binding SelectedAntiHero, Mode=TwoWay}"
                                                 Watermark="Your enemy">
                                    <AutoCompleteBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"/>
                                        </DataTemplate>
                                    </AutoCompleteBox.ItemTemplate>
                                </AutoCompleteBox>

                                <!-- (Optional) Delete button, can be removed if not needed -->
                                <Button Command="{Binding DeleteTextCommand}">
                                    <PathIcon Data="{StaticResource delete_regular}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Best heroes to choose list -->
            <ListBox ItemsSource="{Binding BestToChoose}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <TextBlock Grid.Column="0" Text="{Binding Key}"/>
                            <TextBlock Grid.Column="2" Text="{Binding Value}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </StackPanel>

        <!-- Right-side exclusion list -->
        <views:MinusListView Grid.Column="1"
                             Margin="20,0,0,0"
                             DataContext="{Binding MinusListViewModel}" />
    </Grid>
</Window>
