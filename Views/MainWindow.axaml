<!--
MainWindow

This is the main window for the HeroTableParser application.
It provides the user interface for selecting a data sheet,
entering enemy heroes, and displaying the best heroes to choose.

Layout and Features:
- Sheet Selection: ComboBox for selecting between sheets.
- Path Update: Button to trigger Excel file path update.
- Enemy Input: AutoCompleteBoxes for anti-heroes.
- Best To Choose: List of heroes with their calculated scores.
- MinusListView: Sidebar for managing excluded heroes.

Data Binding:
- Uses MainWindowViewModel as the DataContext.
- AntiHeroes is a collection of AntiHero view models.
- BestToChoose shows key-value pairs (hero name and score).
-->

<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:HeroTableParser.ViewModels"
		xmlns:conv="using:HeroTableParser.Converters"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:views="clr-namespace:HeroTableParser.Views"
		xmlns:utils="clr-namespace:HeroTableParser.Utils"
		mc:Ignorable="d"
		d:DesignWidth="800"
		d:DesignHeight="450"
		x:Class="HeroTableParser.Views.MainWindow"
		x:DataType="vm:MainWindowViewModel"
		Icon="/Assets/avalonia-logo.ico"
		Title="HeroTableParser"
		Background="#1e1e1e"
		WindowState="Maximized"
		WindowStartupLocation="CenterScreen"
		ExtendClientAreaToDecorationsHint="True">

	<Window.Resources>
		<conv:ScoreToBrushConverter x:Key="ScoreToBrushConverter"/>
	</Window.Resources>
	<ScrollViewer>
		<StackPanel Spacing="10">
			<Grid Margin="30, 30, 30, 0" ColumnDefinitions="*, *, *">
				<ItemsControl Grid.Column="0" ItemsSource="{Binding FriendlyHeroes}" HorizontalAlignment="Center" VerticalAlignment="Center">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Grid ColumnDefinitions="Auto, *" HorizontalAlignment="Left">
								<TextBlock Grid.Column="0"
										   Text="Friend: "
										   VerticalAlignment="Center"
										   Margin="0, 10, 10, 10"
										   TextWrapping="Wrap"/>

								<!-- AutoCompleteBox for selecting friendly hero -->
								<AutoCompleteBox Grid.Column="1"
												 HorizontalAlignment="Stretch"
												 Margin="10"
												 ItemsSource="{Binding Source={x:Static utils:HeroService.Instance}, Path=HeroNames}"
												 Text="{Binding NameInput, Mode=TwoWay}"
												 Watermark="Your friend">
									<AutoCompleteBox.ItemTemplate>
										<DataTemplate>
											<TextBlock Text="{Binding}"/>
										</DataTemplate>
									</AutoCompleteBox.ItemTemplate>
								</AutoCompleteBox>
							</Grid>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
				<!-- Main vertical layout -->
				<StackPanel Spacing="20" Margin="10" Grid.Column="1">

					<!-- Sheet selection and path update -->
					<StackPanel Orientation="Horizontal"
								Spacing="10"
								HorizontalAlignment="Left"
								VerticalAlignment="Center"
								Margin="0 10 0 0">
						<TextBlock Text="Selected sheet:" VerticalAlignment="Center"/>
						<ComboBox ItemsSource="{Binding Source={x:Static utils:HeroService.Instance}, Path=Sheets}" SelectedItem="{Binding Source={x:Static utils:HeroService.Instance}, Path=SelectedSheet}"/>
						<Button Content="Path update" Click="NewPath_Click"/>
					</StackPanel>

					<!-- Enemy input controls -->
					<ItemsControl ItemsSource="{Binding AntiHeroes}" HorizontalAlignment="Stretch">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Grid ColumnDefinitions="Auto, *" HorizontalAlignment="Left">
									<TextBlock Grid.Column="0"
											   Text="Enemy: "
											   VerticalAlignment="Center"
											   Margin="0, 10, 10, 10"
											   TextWrapping="Wrap"/>

									<!-- AutoCompleteBox for selecting enemy hero -->
									<AutoCompleteBox Grid.Column="1"
												 HorizontalAlignment="Stretch"
												 Margin="10"
												 ItemsSource="{Binding Source={x:Static utils:HeroService.Instance}, Path=HeroNames}"
												 Text="{Binding NameInput, Mode=TwoWay}"
												 Watermark="Your enemy">
									<AutoCompleteBox.ItemTemplate>
										<DataTemplate>
											<TextBlock Text="{Binding}"/>
										</DataTemplate>
									</AutoCompleteBox.ItemTemplate>
								</AutoCompleteBox>

								</Grid>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>


				</StackPanel>

				<!-- Right-side exclusion list -->
				<views:MinusListView Grid.Column="2"
									 Margin="20,0,0,0"
									 DataContext="{Binding MinusListViewModel}" />
			</Grid>

			<Grid ColumnDefinitions="2*, *">
				<!-- Best heroes to choose list -->
				<ListBox ItemsSource="{Binding BestToChoose}" SelectedItem="{Binding SelectedHero}" Grid.Column="0" Margin="20">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<Border Padding="5" CornerRadius="10">
								<Grid ColumnDefinitions="Auto, *, Auto">
									<TextBlock Grid.Column="0" Text="{Binding Key}"/>
									<TextBlock Grid.Column="2" Text="{Binding Value}"/>
								</Grid>
							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>

				<ListBox ItemsSource="{Binding HeroCounteredBy}" Grid.Column="1" Margin="20">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<Border Background="{Binding Value, Converter={StaticResource ScoreToBrushConverter}, ConverterParameter={Binding RelativeSource={RelativeSource Self}}}"
									Padding="5" CornerRadius="10">
								<Grid ColumnDefinitions="Auto, *, Auto">
									<TextBlock Grid.Column="0" Text="{Binding Key}"/>
									<TextBlock Grid.Column="2" Text="{Binding Value}"/>
								</Grid>
							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
			</Grid>
		</StackPanel>
	</ScrollViewer>
</Window>
