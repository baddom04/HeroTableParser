<!--
  NotificationView Window

  This window displays a notification dialog to the user.
  It is centered on the screen and sized to fit its content, with a dark background.
  The layout consists of:
    - An icon area (SymbolBG) for visual notification symbols.
    - A subject line (Subject) styled as a header.
    - A message area (Message) for the main notification text.
    - An additional info area (AdditionalInfo) for supplementary details.
    - An "OK" button to close the dialog, set as the default action.

  The window uses Avalonia UI controls and is styled for a modern, minimal look.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="250"
        x:Class="HeroTableParser.NotificationView"
        Title="NotificationView"
        ExtendClientAreaToDecorationsHint="True"
        WindowStartupLocation="CenterScreen"
        Width="400" Height="250"
        MinWidth="400" MinHeight="250"
        Background="#2d2d2d"
        SizeToContent="Height">
  <!-- Main layout: vertically stacked, centered content with spacing -->
  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" Spacing="10">
    <!-- Icon area for notification symbol -->
    <Border HorizontalAlignment="Center" x:Name="SymbolBG">
      <PathIcon Classes="incoloredbutton" Name="Symbol"/>
    </Border>
    <!-- Content area: subject, message, additional info, and action button -->
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="40" Margin="20 0">
      <!-- Subject line, styled as a header -->
      <TextBlock HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="NoWrap" Classes="h3" Name="Subject"/>
      <!-- Message and additional info -->
      <StackPanel HorizontalAlignment="Center" Spacing="10">
        <!-- Main notification message -->
        <TextBlock HorizontalAlignment="Center" TextAlignment="Left" x:Name="Message" TextWrapping="Wrap" LineSpacing="2"/>
        <!-- Supplementary information -->
        <TextBlock HorizontalAlignment="Center" TextAlignment="Center" x:Name="AdditionalInfo" TextWrapping="Wrap"/>
      </StackPanel>
      <!-- OK button to close the notification -->
      <Button Content="OK" HorizontalAlignment="Center" Click="Button_Click" IsDefault="True"/>
    </StackPanel>
  </StackPanel>
</Window>